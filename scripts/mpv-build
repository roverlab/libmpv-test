#!/bin/sh
set -e

cd $SRC/mpv*

# mpv 0.39+ uses meson build system
if [ -f "meson.build" ]; then
	echo "Building mpv with meson..."

	# Create cross-file for iOS cross-compilation
	CROSS_FILE=$(mktemp)
	cat > "$CROSS_FILE" << EOF
[binaries]
c = '$(xcrun -sdk iphoneos --find clang)'
cpp = '$(xcrun -sdk iphoneos --find clang++)'
ar = '$(xcrun --find ar)'
strip = '$(xcrun --find strip)'
pkgconfig = 'pkg-config'

[properties]
c_args = ['$CFLAGS']
cpp_args = ['$CXXFLAGS']
c_link_args = ['$LDFLAGS']
needs_exe_wrapper = true

[host_machine]
system = 'darwin'
cpu_family = '$ARCH'
cpu = '$ARCH'
endian = 'little'

[paths]
prefix = '$SCRATCH/$ARCH'
libdir = 'lib'

[built_options]
default_library = 'static'
EOF

	meson setup build \
		--cross-file "$CROSS_FILE" \
		-Dcplayer=false \
		-Dlcms2=disabled \
		-Dlua=disabled \
		-Drubberband=disabled \
		-Dzimg=disabled \
		-Dlibmpv=true \
		-Dios-gl=enabled \
		-Dgl=enabled \
		-Djavascript=disabled \
		-Dlibbluray=disabled \
		-Dvapoursynth=disabled \
		-Duchardet=enabled

	rm -f "$CROSS_FILE"

	if [[ "$ENVIRONMENT" = "development" ]]; then
		meson configure build -Dbuildtype=debug
	fi

	ninja -C build -j$(sysctl -n hw.ncpu 2>/dev/null || echo 4)
	ninja -C build install

	# Copy libmpv.a to lib directory
	find "$SCRATCH/$ARCH" -name "libmpv.a" -exec cp {} "$SCRATCH/$ARCH/lib/" \; 2>/dev/null || true
else
	echo "Building mpv with waf (legacy)..."

	OPTS="--prefix=$SCRATCH/$ARCH \
		--exec-prefix=$SCRATCH/$ARCH \
		--disable-cplayer \
		--disable-lcms2 \
		--disable-lua \
		--disable-rubberband \
		--disable-zimg \
		--enable-libmpv-static \
		--enable-ios-gl \
		--enable-gl \
		--disable-javascript \
		--disable-libbluray \
		--disable-vapoursynth \
		--enable-uchardet \
		--enable-lgpl"

	if [[ "$ENVIRONMENT" = "development" ]]; then
		OPTS="$OPTS --disable-optimize"
	fi

	./bootstrap.py
	./waf configure $OPTS
	./waf build -j4
fi