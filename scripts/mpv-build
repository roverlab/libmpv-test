#!/bin/sh
set -e

cd $SRC/mpv*

echo "Building mpv with meson (libplacebo as subproject)..."
echo "  ARCH=$ARCH"
echo "  SDKPATH=$SDKPATH"
echo "  SCRATCH=$SCRATCH"

# Validate required environment variables
if [ -z "$ARCH" ] || [ -z "$SDKPATH" ] || [ -z "$SCRATCH" ]; then
    echo "ERROR: Required environment variables not set"
    echo "  ARCH=$ARCH"
    echo "  SDKPATH=$SDKPATH"
    echo "  SCRATCH=$SCRATCH"
    exit 1
fi

# Determine target based on architecture
if [ "$ARCH" = "arm64" ]; then
    TARGET_TRIPLE="arm64-apple-ios"
    SDK_NAME="iphoneos"
    CPU_FAMILY="aarch64"
    CPU="aarch64"
elif [ "$ARCH" = "x86_64" ]; then
    TARGET_TRIPLE="x86_64-apple-ios13.0-simulator"
    SDK_NAME="iphonesimulator"
    CPU_FAMILY="x86_64"
    CPU="x86_64"
else
    echo "ERROR: Unsupported architecture: $ARCH"
    exit 1
fi

# Create cross-file for iOS cross-compilation
CROSS_FILE=$(mktemp)
cat > "$CROSS_FILE" << EOF
[binaries]
c = ['\$(xcrun -sdk $SDK_NAME --find clang)', '-target', '$TARGET_TRIPLE', '-isysroot', '$SDKPATH', '-miphoneos-version-min=11.0']
cpp = ['\$(xcrun -sdk $SDK_NAME --find clang++)', '-target', '$TARGET_TRIPLE', '-isysroot', '$SDKPATH', '-miphoneos-version-min=11.0']
objc = ['\$(xcrun -sdk $SDK_NAME --find clang)', '-target', '$TARGET_TRIPLE', '-isysroot', '$SDKPATH', '-miphoneos-version-min=11.0']
objcpp = ['\$(xcrun -sdk $SDK_NAME --find clang++)', '-target', '$TARGET_TRIPLE', '-isysroot', '$SDKPATH', '-miphoneos-version-min=11.0']
ar = '\$(xcrun --find ar)'
strip = '\$(xcrun --find strip)'
pkg-config = 'pkg-config'

[host_machine]
system = 'darwin'
cpu_family = '$CPU_FAMILY'
cpu = '$CPU'
endian = 'little'

[built-in options]
prefix = '$SCRATCH/$ARCH'
libdir = 'lib'
default_library = 'static'
EOF

# Set buildtype and compiler flags based on environment
BUILDTYPE="release"
C_ARGS="-fembed-bitcode -Os"
CPP_ARGS="-fembed-bitcode -Os"
C_LINK_ARGS="-lbz2 -fembed-bitcode -Os"

if [[ "$ENVIRONMENT" = "development" ]]; then
    BUILDTYPE="debug"
    C_ARGS="-fembed-bitcode -g2 -Og"
    CPP_ARGS="-fembed-bitcode -g2 -Og"
    C_LINK_ARGS="-lbz2 -fembed-bitcode -g2 -Og"
fi

# Convert space-separated flags to meson array format: ['-a', '-b', '-c']
to_meson_array() {
    local input="$1"
    local result=""
    for word in $input; do
        if [ -n "$result" ]; then result="$result, "; fi
        result="'$word'"
    done
    echo "[$result]"
}

# Write build options to cross-file (c_args, cpp_args, c_link_args)
cat >> "$CROSS_FILE" << EOF
c_args = $(to_meson_array "$C_ARGS")
cpp_args = $(to_meson_array "$CPP_ARGS")
c_link_args = $(to_meson_array "$C_LINK_ARGS")
EOF

echo "Cross-file created at: $CROSS_FILE"
cat "$CROSS_FILE" | head -20

meson setup build \
	--cross-file "$CROSS_FILE" \
	--buildtype=$BUILDTYPE \
	--wrap-mode=nodownload \
	-Ddefault_library=static \
	-Dcplayer=false \
	-Dgpl=false \
	-Dlibmpv=true \
	-Dlua=disabled \
	-Djavascript=disabled \
	-Dcocoa=disabled \
	-Dswift-build=disabled \
	-Dmacos-cocoa-cb=disabled \
	-Dcoreaudio=disabled \
	-Daudiounit=enabled \
	-Davfoundation=disabled \
	-Dvideotoolbox-pl=disabled \
	-Dvideotoolbox-gl=disabled \
	-Dgl=disabled \
	-Degl=disabled \
	-Dvulkan=disabled \
	-Dplain-gl=disabled \
	-Dx11=disabled \
	-Dwayland=disabled \
	-Dalsa=disabled \
	-Dios-gl=disabled \
	-Dmanpage-build=disabled \
	-Dhtml-build=disabled \
	-Dpdf-build=disabled \
	-Dlibplacebo:opengl=disabled \
	-Dlibplacebo:vulkan=disabled \
	-Dlibass:require-system-font-provider=false \
	-Dfreetype2:harfbuzz=disabled \
	-Dfreetype2:hvf=disabled \
	-Diconv=disabled \
	-Dlibarchive=disabled \
	-Duchardet=disabled \
	-Dmacos-media-player=disabled

ninja -C build -j$(sysctl -n hw.ncpu 2>/dev/null || echo 4)
ninja -C build install

rm -f "$CROSS_FILE"

# Copy libmpv.a to lib directory
find "$SCRATCH/$ARCH" -name "libmpv.a" -exec cp {} "$SCRATCH/$ARCH/lib/" \; 2>/dev/null || true
